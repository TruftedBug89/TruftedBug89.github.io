            "@type": "FAQPage",
            "@id": "https://truftedbug89.github.io/#faq",
            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "Is Chinese Master free to use?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes, Chinese Master is completely free and open source. No accounts, no servers, no tracking unless you opt in."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Does Chinese Master work offline?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes, it is a Progressive Web App (PWA). After your first visit, it caches all resources and works fully offline. You can install it on your device from your browser."
                    }
                },
                {
                    "@type": "Question",
                    "name": "What HSK levels does Chinese Master cover?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Chinese Master covers HSK 1 through HSK 5, with over 5000 vocabulary words, listening exercises, reading passages, grammar lessons, and speaking practice."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Does Chinese Master track my progress?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes, all progress is stored locally on your device using browser storage. It includes XP, levels, daily streaks, achievements, and a spaced-repetition review system. You can export and import your progress as a JSON backup."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Can I use Chinese Master on my phone?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes, Chinese Master is fully responsive and optimized for mobile. Install it as a PWA from your browser (Chrome, Edge, Safari) for a native app-like experience."
                    }
                },
                {
                    "@type": "Question",
                    "name": "How does the placement test work?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "The placement test uses an adaptive algorithm that starts at HSK 2 and adjusts difficulty based on your answers. In about 20 questions across 5 minutes, it estimates your HSK level and recommends study materials."
                    }
                }
            ]
